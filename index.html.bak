                              </div>
                            </div>
                            <svg class="size-[9px] corner-accent tl" viewBox="0 0 10 10" fill="none"><path d="M0.5 0.2L0.5 9.2M0.2 0.5L9.2 0.5" stroke="currentColor"/></svg>
                            <svg class="size-[9px] corner-accent tr" viewBox="0 0 10 10" fill="none"><path d="M0.5 0.2L0.5 9.2M0.2 0.5L9.2 0.5" stroke="currentColor"/></svg>
                            <svg class="size-[9px] corner-accent bl" viewBox="0 0 10 10" fill="none"><path d="M0.5 0.2L0.5 9.2M0.2 0.5L9.2 0.5" stroke="currentColor"/></svg>
                            <svg class="size-[9px] corner-accent br" viewBox="0 0 10 10" fill="none"><path d="M0.5 0.2L0.5 9.2M0.2 0.5L9.2 0.5" stroke="currentColor"/></svg>
                          </a>
                        </div>
                        <p class="p3-mono opacity-60 text-[10px]">+91 22 2288 0088 · Nariman Point, Mumbai</p>
                      </div>
                    </div>
                    <div class="ml-auto max-w-[90px] md:max-w-full flex items-start justify-end">
                      <img src="logo.png" alt="Intensive Fiscal" style="max-height:80px; width:auto; opacity:0.3;" />
                    </div>
                    <nav class="order-1 col-span-2 flex flex-col gap-[32px] md:order-2 md:col-span-1 md:justify-end">
                      <ul class="flex flex-col gap-[4px]">
                        <li><a href="#services" class="group/button h5 relative isolate flex items-center gap-[8px] uppercase"><div class="bg-rich-carbon -mt-[3.5px] size-[25px] -translate-x-full rounded-[8px] opacity-0 blur-[32px] transition-[transform,translate,opacity,filter] duration-500 ease-(--easing) group-hover/button:translate-x-0 group-hover/button:opacity-100 group-hover/button:blur-[0px]"></div><div class="relative isolate flex -translate-x-[33px] overflow-hidden transition-transform duration-500 ease-(--easing) group-hover/button:translate-x-0"><span class="transition-transform duration-500 ease-(--easing) group-hover/button:-translate-y-full">Services</span><span class="absolute inset-0 translate-y-full transition-transform duration-500 ease-(--easing) group-hover/button:translate-y-0" aria-hidden="true">Services</span></div></a></li>
                        <li><a href="#sectors" class="group/button h5 relative isolate flex items-center gap-[8px] uppercase"><div class="bg-rich-carbon -mt-[3.5px] size-[25px] -translate-x-full rounded-[8px] opacity-0 blur-[32px] transition-[transform,translate,opacity,filter] duration-500 ease-(--easing) group-hover/button:translate-x-0 group-hover/button:opacity-100 group-hover/button:blur-[0px]"></div><div class="relative isolate flex -translate-x-[33px] overflow-hidden transition-transform duration-500 ease-(--easing) group-hover/button:translate-x-0"><span class="transition-transform duration-500 ease-(--easing) group-hover/button:-translate-y-full">Sectors</span><span class="absolute inset-0 translate-y-full transition-transform duration-500 ease-(--easing) group-hover/button:translate-y-0" aria-hidden="true">Sectors</span></div></a></li>
                        <li><a href="#approach" class="group/button h5 relative isolate flex items-center gap-[8px] uppercase"><div class="bg-rich-carbon -mt-[3.5px] size-[25px] -translate-x-full rounded-[8px] opacity-0 blur-[32px] transition-[transform,translate,opacity,filter] duration-500 ease-(--easing) group-hover/button:translate-x-0 group-hover/button:opacity-100 group-hover/button:blur-[0px]"></div><div class="relative isolate flex -translate-x-[33px] overflow-hidden transition-transform duration-500 ease-(--easing) group-hover/button:translate-x-0"><span class="transition-transform duration-500 ease-(--easing) group-hover/button:-translate-y-full">Approach</span><span class="absolute inset-0 translate-y-full transition-transform duration-500 ease-(--easing) group-hover/button:translate-y-0" aria-hidden="true">Approach</span></div></a></li>
                        <li><a href="#clients" class="group/button h5 relative isolate flex items-center gap-[8px] uppercase"><div class="bg-rich-carbon -mt-[3.5px] size-[25px] -translate-x-full rounded-[8px] opacity-0 blur-[32px] transition-[transform,translate,opacity,filter] duration-500 ease-(--easing) group-hover/button:translate-x-0 group-hover/button:opacity-100 group-hover/button:blur-[0px]"></div><div class="relative isolate flex -translate-x-[33px] overflow-hidden transition-transform duration-500 ease-(--easing) group-hover/button:translate-x-0"><span class="transition-transform duration-500 ease-(--easing) group-hover/button:-translate-y-full">Clients</span><span class="absolute inset-0 translate-y-full transition-transform duration-500 ease-(--easing) group-hover/button:translate-y-0" aria-hidden="true">Clients</span></div></a></li>
                      </ul>
                      <div class="hidden md:block">
