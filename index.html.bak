                          <a href="mailto:info@intensivefiscal.com" class="group/button hover:animate-glitch-hover relative isolate block" data-theme="dark">
                            <div class="flex h-[40px] items-center justify-center px-[20px]">
                              <div class="group-data-[theme=dark]/button:bg-rich-carbon size-[10px] -translate-x-[24px] rounded-[3px] opacity-0 blur-[20px] transition-all duration-400 ease-(--easing) group-hover/button:-translate-x-[5px] group-hover/button:opacity-100 group-hover/button:blur-[0px]"></div>
