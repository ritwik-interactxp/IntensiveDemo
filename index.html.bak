  <!-- Alpine.js -->
  <script src="https://cdn.jsdelivr.net/npm/alpinejs@3.x.x/dist/cdn.min.js" defer></script>

  <script>
    // ─── LOADER ───────────────────────────────────────────────────
    (function() {
      const pct = document.getElementById('loader-pct');
      const loader = document.getElementById('loader');
      const duration = 1600;
      const start = Date.now();
      function ease(t) {
        const p1x=0.62,p1y=0.16,p2x=0.13,p2y=1.01;
        const cx=3*p1x,bx=3*(p2x-p1x)-cx,ax=1-cx-bx;
        const cy=3*p1y,by=3*(p2y-p1y)-cy,ay=1-cy-by;
        let x=t;
        for(let i=0;i<4;i++){const cx2=((ax*x+bx)*x+cx)*x;const sl=(3*ax*x+2*bx)*x+cx;if(sl===0)break;x-=(cx2-t)/sl;}
        return((ay*x+by)*x+cy)*x;
      }
      document.body.style.overflow='hidden';
      function animate() {
        const elapsed = Date.now()-start;
        const tp = Math.min(elapsed/duration,1);
        const p = Math.round(ease(tp)*100);
        if(pct) pct.textContent = p+'%';
        if(tp < 1) { requestAnimationFrame(animate); }
        else {
          document.body.style.overflow='';
          loader.style.transition='opacity 0.6s ease';
          loader.style.opacity='0';
          setTimeout(()=>{ loader.style.display='none'; },700);
        }
      }
      requestAnimationFrame(animate);
    })();

    // ─── CURSOR ───────────────────────────────────────────────────
    const cursor = document.getElementById('wqf-cursor');
    let mx=0,my=0,cx=0,cy=0;
    document.addEventListener('mousemove',e=>{
      mx=e.clientX; my=e.clientY;
      cursor.style.opacity='1';
    });
    (function moveCursor(){
      cx+=(mx-cx)*0.12; cy+=(my-cy)*0.12;
      cursor.style.transform=`translate(${cx}px,${cy}px) translate(-50%,-50%)`;
      requestAnimationFrame(moveCursor);
    })();

    // ─── HEADER SCROLL ────────────────────────────────────────────
    const header = document.getElementById('site-header');
    const headerBar = document.getElementById('header-bar');
    const headerLogo = document.getElementById('header-logo');
    const logoH = document.getElementById('logo-h');
    const logoV = document.getElementById('logo-v');
    let lastY=0, hidden=false, scrolled=false;
    window.addEventListener('scroll',()=>{
      const sy=window.scrollY;
      const delta=sy-lastY;
      scrolled=sy>window.innerHeight/4;
      if(sy>window.innerHeight){
        if(delta>50&&!hidden){hidden=true;header.style.transform='translateY(-120%)';}
        else if(delta<-50&&hidden){hidden=false;header.style.transform='';}
      } else { hidden=false; header.style.transform=''; }
      if(Math.abs(delta)>50) lastY=sy;
      if(scrolled){
        headerLogo.style.width='120px';
        logoV.style.transform='translateY(0)';
        logoV.style.opacity='1';
        logoH.style.opacity='0';
        headerBar.style.background='rgba(17,17,17,0.95)';
        headerBar.style.borderRadius='8px';
        headerBar.style.padding='4px 12px';
      } else {
        headerLogo.style.width='220px';
        logoV.style.transform='translateY(100%)';
        logoV.style.opacity='0';
        logoH.style.opacity='1';
        headerBar.style.background='transparent';
        headerBar.style.borderRadius='0';
        headerBar.style.padding='0';
      }
    },{passive:true});

    // ─── MOBILE MENU ─────────────────────────────────────────────
    const mobMenu = document.getElementById('mob-menu');
    const mobToggle = document.getElementById('mob-toggle');
    let mobOpen=false;
    mobToggle.addEventListener('click',()=>{
      mobOpen=!mobOpen;
      if(mobOpen){
        mobMenu.style.display='flex';
        requestAnimationFrame(()=>{ mobMenu.style.clipPath='inset(0 0 0% 0)'; });
      } else { closeMob(); }
    });
    function closeMob(){
      mobOpen=false;
      mobMenu.style.clipPath='inset(0 0 100% 0)';
      setTimeout(()=>{ mobMenu.style.display='none'; },400);
    }
    window.closeMob=closeMob;
  </script>
</body>
</html>
