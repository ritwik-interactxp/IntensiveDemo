                    x-data="{ init() { const mm = gsap.matchMedia(); mm.add('(min-width: 768px)', () => { ScrollTrigger.create({ trigger: this.$el, start: 'top 80px', endTrigger: '#clients', end: 'bottom 50%', pin: this.$el, pinSpacing: false, invalidateOnRefresh: true }); }); } }" data-lag="0.2">
